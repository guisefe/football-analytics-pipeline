# football-data.org — free tier: football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# API-Football — free tier: dashboard.api-football.com/register
API_FOOTBALL_KEY=your_key_here

# Airflow
AIRFLOW_UID=50000

# DuckDB — path inside Docker volume (do not change unless you know what you're doing)
DUCKDB_PATH=/opt/airflow/data/warehouse.duckdb
